rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /transactions/{transactionId} {

      function isSignedIn() {
        return request.auth != null;
      }

      function isLender() {
        return isSignedIn()
          && resource.data.lenderId is string
          && request.auth.uid == resource.data.lenderId;
      }

      function isBorrower() {
        return isSignedIn()
          && resource.data.borrowerId is string
          && request.auth.uid == resource.data.borrowerId;
      }

      allow read: if isLender() || isBorrower();

      allow create: if isSignedIn()
        && request.auth.uid == request.resource.data.lenderId
        && request.resource.data.borrowerId is string;

      allow update: if isSignedIn() && (isLender() || isBorrower());
    }

    match /itemRequests/{docId} {
      allow read, write: if request.auth != null;
    }

    match /itemListings/{docId} {
      allow read, write: if request.auth != null;
    }

    match /userProfiles/{userId} {
       allow read, write: if request.auth != null;
    }
  }
}
