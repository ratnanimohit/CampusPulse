rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --------------------------------
    // Helper Functions
    // --------------------------------

    /**
     * Returns true if the user is authenticated.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * Returns true if the authenticated user's UID matches the provided userId.
     * This is the fundamental check for document ownership.
     * @param userId The UID of the user to check against.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * Returns true if the document exists AND the authenticated user is the owner.
     * Used for safe update and delete operations.
     * @param userId The UID of the user to check against.
     */
    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }
    
    /**
     * Returns true if the authenticated user is either the lender or the borrower
     * of an existing transaction document.
     */
    function isTransactionParticipant() {
      return resource != null && isSignedIn() && (request.auth.uid == resource.data.lenderId || request.auth.uid == resource.data.borrowerId);
    }
    
    /**
     * Validates that the 'id' field of a user profile is immutable on update.
     */
    function isUserProfileIdImmutable() {
      return request.resource.data.id == resource.data.id;
    }

    /**
     * Validates that the 'ownerId' field of an item listing is immutable on update.
     */
    function isListingOwnerImmutable() {
      return request.resource.data.ownerId == resource.data.ownerId;
    }

    /**
     * Validates that the 'requesterId' field of an item request is immutable on update.
     */
    function isRequestRequesterImmutable() {
      return request.resource.data.requesterId == resource.data.requesterId;
    }

    /**
     * Validates that the participant IDs ('lenderId', 'borrowerId') of a transaction are immutable on update.
     */
    function areTransactionParticipantsImmutable() {
      return request.resource.data.lenderId == resource.data.lenderId && request.resource.data.borrowerId == resource.data.borrowerId;
    }

    // --------------------------------
    // Collection Rules
    // --------------------------------

    /**
     * @description Manages user profile documents. Access is restricted to the owner.
     * @path /userProfiles/{userId}
     */
    match /userProfiles/{userId} {
      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isOwner(userId) && resource != null && isUserProfileIdImmutable();
      allow delete: if false;
    }

    /**
     * @description Manages public item listings. Anyone can read, but only the owner can write.
     * @path /itemListings/{itemId}
     */
    match /itemListings/{itemId} {
      allow get: if true;
      allow list: if true;
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      allow update: if isExistingOwner(resource.data.ownerId) && isListingOwnerImmutable();
      allow delete: if isExistingOwner(resource.data.ownerId);
    }

    /**
     * @description Manages private transaction records. Any authenticated user can read/write.
     * @path /transactions/{transactionId}
     */
    match /transactions/{transactionId} {
      allow read, write: if isSignedIn();
    }

    /**
     * @description Manages public requests for items. Anyone can read. Only the requester can create/update. Anyone can delete (as part of fulfillment).
     * @path /itemRequests/{itemRequestId}
     */
    match /itemRequests/{itemRequestId} {
      allow get: if true;
      allow list: if true;
      allow create: if isSignedIn() && request.resource.data.requesterId == request.auth.uid;
      allow update: if isExistingOwner(resource.data.requesterId) && isRequestRequesterImmutable();
      allow delete: if isSignedIn();
    }
  }
}
