rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /transactions/{transactionId} {
      // Allow any signed-in user to do anything.
      // THIS IS TEMPORARY and for development purposes.
      allow read, write: if request.auth != null;
    }

    match /itemRequests/{itemRequestId} {
      // Allow any signed-in user to do anything.
      // THIS IS TEMPORARY and for development purposes.
      allow read, write: if request.auth != null;
    }

    match /itemListings/{listingId} {
      // Allow any signed-in user to do anything.
      // THIS IS TEMPORARY and for development purposes.
      allow read, write: if request.auth != null;
    }

    match /userProfiles/{userId} {
      // Allow any signed-in user to do anything.
      // THIS IS TEMPORARY and for development purposes.
      allow read, write: if request.auth != null;
    }
  }
}
