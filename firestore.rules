rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /transactions/{transactionId} {

      function signedIn() {
        return request.auth != null;
      }

      function lender() {
        return signedIn()
          && resource.data.lenderId is string
          && request.auth.uid == resource.data.lenderId;
      }

      function borrower() {
        return signedIn()
          && resource.data.borrowerId is string
          && request.auth.uid == resource.data.borrowerId;
      }

      allow read: if lender() || borrower();

      allow create: if signedIn()
        && request.auth.uid == request.resource.data.lenderId
        && request.resource.data.borrowerId is string;

      allow update: if lender() || borrower();
    }

    match /itemRequests/{docId} {
      allow read, write: if request.auth != null;
    }

    match /itemListings/{docId} {
      allow read, write: if request.auth != null;
    }

    match /userProfiles/{userId} {
       allow read, write: if request.auth != null;
    }
  }
}
