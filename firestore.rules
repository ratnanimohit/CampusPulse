rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /transactions/{transactionId} {

      function isParticipant() {
        return request.auth != null &&
          (request.auth.uid == resource.data.lenderId ||
           request.auth.uid == resource.data.borrowerId);
      }

      allow read: if isParticipant();
      
      allow create: if request.auth != null && request.auth.uid == request.resource.data.lenderId;

      allow update: if isParticipant();
      
      allow delete: if false; // Transactions should not be deletable for history.
    }

    match /itemRequests/{itemRequestId} {
        allow read, create: if request.auth != null;
        // Only the user who created the request can delete it.
        allow delete: if request.auth != null && request.auth.uid == resource.data.requesterId;
    }

    match /itemListings/{listingId} {
        allow read: if true; // All users can see all listings
        // Only the owner can create, update or delete their listing
        allow write: if request.auth != null && request.auth.uid == resource.data.ownerId;
    }

    match /userProfiles/{userId} {
       // A user can read any profile, but can only write to their own.
       allow read: if request.auth != null;
       allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
