rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /transactions/{transactionId} {

      function isParticipant() {
        // Check the incoming request data on create, and the existing resource on update/delete
        let data = request.method == 'create' ? request.resource.data : resource.data;
        return request.auth != null &&
          (request.auth.uid == data.fulfillerId ||
           request.auth.uid == data.requesterId);
      }

      allow get: if request.auth != null &&
        (
          request.auth.uid == resource.data.requesterId ||
          request.auth.uid == resource.data.fulfillerId
        );

      allow list: if request.auth != null;

      allow update: if request.auth != null &&
        (
          // fulfiller claiming the request
          (
            request.auth.uid != resource.data.requesterId &&
            resource.data.fulfillerId == null &&
            request.resource.data.fulfillerId == request.auth.uid
          )

          ||

          // requester verifying code / completing
          (
            request.auth.uid == resource.data.requesterId
          )
        );
      
      allow create: if request.auth != null && request.auth.uid == request.resource.data.fulfillerId;
      
      allow delete: if false; // Transactions should not be deletable for history.
    }

    match /itemRequests/{itemRequestId} {
        allow read, create: if request.auth != null;
        // Only the user who created the request can delete it.
        allow delete: if request.auth != null && request.auth.uid == resource.data.requesterId;
    }

    match /itemListings/{listingId} {
        allow read: if true; // All users can see all listings
        // Only the owner can create, update or delete their listing
        allow write: if request.auth != null && request.auth.uid == resource.data.ownerId;
    }

    match /userProfiles/{userId} {
       // A user can read any profile, but can only write to their own.
       allow read: if request.auth != null;
       allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
