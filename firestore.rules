rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /transactions/{id} {
      allow get: if request.auth != null &&
        (request.auth.uid == resource.data.requesterId ||
         request.auth.uid == resource.data.fulfillerId);

      allow list: if request.auth != null && (request.query.where.get('requesterId') == request.auth.uid || request.query.where.get('fulfillerId') == request.auth.uid);

      allow write: if request.auth != null; // Simplified for now
    }

    match /itemRequests/{docId} {
      allow read, write: if request.auth != null;
    }

    match /itemListings/{docId} {
      allow read, write: if request.auth != null;
    }

    match /userProfiles/{userId} {
       allow read, write: if request.auth != null;
    }
  }
}
