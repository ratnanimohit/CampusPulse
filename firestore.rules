rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /transactions/{id} {
      // Read allowed to both parties
      allow read: if request.auth != null &&
        (request.auth.uid == resource.data.requesterId ||
         request.auth.uid == resource.data.fulfillerId);

      // Write rules for transaction updates
      allow write: if request.auth != null; // Simplified for now, can be tightened
    }

    match /itemRequests/{docId} {
      allow read, write: if request.auth != null;
    }

    match /itemListings/{docId} {
      allow read, write: if request.auth != null;
    }

    match /userProfiles/{userId} {
       allow read, write: if request.auth != null;
    }
  }
}
