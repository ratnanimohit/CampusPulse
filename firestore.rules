rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /transactions/{transactionId} {

      function isLender() {
        return request.auth.uid == resource.data.lenderId;
      }

      function isBorrower() {
        return request.auth.uid == resource.data.borrowerId;
      }

      function isParticipant() {
        return isLender() || isBorrower();
      }

      // READ: both lender & borrower
      allow read: if request.auth != null && isParticipant();

      // CREATE: lender only
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.lenderId
        && request.resource.data.borrowerId != null;

      // UPDATE rules
      allow update: if request.auth != null && (
        
        // LENDER: generate handover code
        (
          isLender()
          && resource.data.status == "CREATED"
          && request.resource.data.status == "HANDOVER_PENDING"
        )

        ||

        // BORROWER: verify handover & generate return code
        (
          isBorrower()
          && resource.data.status == "HANDOVER_PENDING"
          && request.resource.data.status == "ACTIVE"
        )

        ||

        // BORROWER: generate return code
        (
          isBorrower()
          && resource.data.status == "ACTIVE"
          && request.resource.data.status == "RETURN_PENDING"
        )

        ||

        // LENDER: verify return
        (
          isLender()
          && resource.data.status == "RETURN_PENDING"
          && request.resource.data.status == "COMPLETED"
        )
        
        ||

        // ANY PARTICIPANT: cancel
        (
          isParticipant()
          && request.resource.data.status == "CANCELLED"
        )
      );
    }

    match /itemRequests/{docId} {
      allow read, write: if request.auth != null;
    }

    match /itemListings/{docId} {
      allow read, write: if request.auth != null;
    }

    match /userProfiles/{userId} {
       allow read, write: if request.auth != null;
    }
  }
}

    