rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /transactions/{docId} {
      allow read, write: if request.auth != null;
    }

    match /itemRequests/{docId} {
      allow read, write: if request.auth != null;
    }

    match /itemListings/{docId} {
      allow read, write: if request.auth != null;
    }

    match /userProfiles/{userId} {
       allow read, write: if request.auth != null;
    }
  }
}

    