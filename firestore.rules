rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /transactions/{id} {

      // ✅ ANY signed-in user can open a transaction page
      allow get: if request.auth != null;

      // ✅ Needed for dashboards / lists
      allow list: if request.auth != null;

      // ✅ Creating a request
      allow create: if request.auth != null;

      // ✅ Updating (fulfill / verify)
      allow update: if request.auth != null;

      match /messages/{messageId} {
        // Allow participants to read/write.
        // THIS IS TEMPORARY and for development purposes.
        allow read, write: if request.auth != null;
      }
    }

    match /itemRequests/{itemRequestId} {
      // Allow any signed-in user to do anything.
      // THIS IS TEMPORARY and for development purposes.
      allow read, write: if request.auth != null;
    }

    match /itemListings/{listingId} {
      // Allow any signed-in user to do anything.
      // THIS IS TEMPORARY and for development purposes.
      allow read, write: if request.auth != null;
    }

    match /userProfiles/{userId} {
      // Allow any signed-in user to do anything.
      // THIS IS TEMPORARY and for development purposes.
      allow read, write: if request.auth != null;
    }

    match /feedback/{feedbackId} {
      // Allow any signed-in user to do anything.
      // THIS IS TEMPORARY and for development purposes.
      allow read, write: if request.auth != null;
    }
  }
}
